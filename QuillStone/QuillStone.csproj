<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>QuillStone</AssemblyName>
    <RootNamespace>QuillStone</RootNamespace>
    <ApplicationIcon>Assets\Icons\icon.ico</ApplicationIcon>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.2.3" />
    <PackageReference Include="Avalonia.Desktop" Version="11.2.3" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.2.3" />
  </ItemGroup>

  <ItemGroup>
    <AvaloniaResource Include="Assets/Fonts/**" />
    <AvaloniaResource Include="Assets/Icons/**" />
  </ItemGroup>

  <ItemGroup>
    <!-- Design mock file, not part of the runtime window types -->
    <AvaloniaXaml Remove="Styles/Theme/MainWindow.axaml" />
    <AvaloniaResource Remove="Styles/Theme/MainWindow.axaml" />
    <None Include="Styles/Theme/MainWindow.axaml" />
  </ItemGroup>

</Project>
