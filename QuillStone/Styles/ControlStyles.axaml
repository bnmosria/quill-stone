<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Control Styles — QuillStone
        ══════════════════════════════════════════════════════════════════════
        Applies design tokens (defined in Styles/Tokens.axaml) to UI controls.
        All values are referenced via {DynamicResource}; change a token in
        Tokens.axaml and every control using it updates automatically.

        Structure
        ─────────────────────────────────────────────────────────────────────
        1. Toolbar buttons  (.toolbar-btn)
        2. Caption buttons  (.caption-button / .caption-close, Windows only)
        ══════════════════════════════════════════════════════════════════════
    -->

    <!-- ── 1. Toolbar buttons ─────────────────────────────────────── -->
    <!--
        Apply the class "toolbar-btn" to any formatting toolbar Button.
        The style normalises dimensions, removes Fluent default borders, and
        adds subtle overlay feedback on hover and press.
    -->
    <Style Selector="Button.toolbar-btn">
        <Setter Property="Height"                   Value="{DynamicResource ToolbarButtonHeight}" />
        <Setter Property="MinWidth"                 Value="{DynamicResource ToolbarButtonMinWidth}" />
        <Setter Property="Padding"                  Value="{DynamicResource ToolbarButtonPadding}" />
        <Setter Property="Margin"                   Value="{DynamicResource ToolbarButtonMargin}" />
        <Setter Property="Background"               Value="Transparent" />
        <Setter Property="BorderBrush"              Value="Transparent" />
        <Setter Property="BorderThickness"          Value="0" />
        <Setter Property="CornerRadius"             Value="{DynamicResource RadiusControl}" />
        <Setter Property="FontSize"                 Value="{DynamicResource FontSizeBase}" />
        <Setter Property="Focusable"                Value="False" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment"   Value="Center" />
    </Style>

    <Style Selector="Button.toolbar-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushOverlayHover}" />
    </Style>

    <Style Selector="Button.toolbar-btn:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushOverlayPress}" />
    </Style>

    <!-- ── 2. Caption buttons (Windows custom title bar) ──────────── -->
    <!--
        These styles mirror the standard Windows 11 caption-button behaviour.
        They are scoped to Window.platform-windows so they never apply on
        macOS or Linux, where the native window chrome is used instead.
    -->
    <Style Selector="Window.platform-windows Button.caption-button">
        <Setter Property="Width"                    Value="{DynamicResource CaptionButtonWidth}" />
        <Setter Property="Height"                   Value="{DynamicResource CaptionButtonHeight}" />
        <Setter Property="Padding"                  Value="0" />
        <Setter Property="Background"               Value="Transparent" />
        <Setter Property="BorderBrush"              Value="Transparent" />
        <Setter Property="BorderThickness"          Value="0" />
        <Setter Property="CornerRadius"             Value="0" />
        <Setter Property="FontSize"                 Value="{DynamicResource FontSizeCaption}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment"   Value="Center" />
    </Style>

    <Style Selector="Window.platform-windows Button.caption-button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushOverlayHover}" />
    </Style>

    <Style Selector="Window.platform-windows Button.caption-button:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushOverlayPress}" />
    </Style>

    <!-- Close button: Windows 11 red on hover / press -->
    <Style Selector="Window.platform-windows Button.caption-close:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushCaptionCloseHover}" />
    </Style>

    <Style Selector="Window.platform-windows Button.caption-close:pointerover">
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="Window.platform-windows Button.caption-close:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushCaptionClosePress}" />
    </Style>

</Styles>
