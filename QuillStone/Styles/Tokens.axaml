<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Design Tokens — QuillStone
        ══════════════════════════════════════════════════════════════════════
        All design decisions (color, spacing, radius, typography, sizes)
        live here.  To retheme the app, edit values in this file only.
        Reference a token with {DynamicResource TokenKey} in any XAML file.

        Structure
        ─────────────────────────────────────────────────────────────────────
        1. Colors        — raw Color values
        2. Brushes       — SolidColorBrush built from the Color tokens
        3. Corner Radius — CornerRadius tokens (3–4 px, per design spec)
        4. Typography    — font sizes and font families
        5. Sizes         — fixed heights, widths for repeated controls
        6. Spacing       — Thickness tokens for padding and margin
        ══════════════════════════════════════════════════════════════════════
    -->

    <!-- ── 1. Colors ───────────────────────────────────────────────── -->

    <!-- Main content background, calm off-white/light-grey -->
    <Color x:Key="ColorSurface">#F3F4F6</Color>
    <!-- Toolbar / secondary surface, slightly darker -->
    <Color x:Key="ColorSurfaceAlt">#E9EBF0</Color>
    <!-- Window chrome background: surface colour at ~80 % opacity for title-bar region -->
    <Color x:Key="ColorWindowChrome">#CCF3F4F6</Color>
    <!-- Borders and separator lines -->
    <Color x:Key="ColorBorder">#CDD1D8</Color>

    <!-- Text -->
    <Color x:Key="ColorTextPrimary">#1D2432</Color>
    <Color x:Key="ColorTextMuted">#5E6A7D</Color>

    <!-- Interactive overlay tints (used in hover/press states) -->
    <Color x:Key="ColorOverlayHover">#18000000</Color>
    <Color x:Key="ColorOverlayPress">#30000000</Color>

    <!-- Caption close-button accent (Windows 11 red) -->
    <Color x:Key="ColorCaptionCloseHover">#C42B1C</Color>
    <Color x:Key="ColorCaptionClosePress">#E81123</Color>

    <!-- ── 2. Brushes ───────────────────────────────────────────────── -->

    <SolidColorBrush x:Key="BrushSurface"           Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="BrushSurfaceAlt"        Color="{StaticResource ColorSurfaceAlt}" />
    <SolidColorBrush x:Key="BrushWindowChrome"      Color="{StaticResource ColorWindowChrome}" />
    <SolidColorBrush x:Key="BrushBorder"            Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="BrushTextPrimary"       Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="BrushTextMuted"         Color="{StaticResource ColorTextMuted}" />
    <SolidColorBrush x:Key="BrushOverlayHover"      Color="{StaticResource ColorOverlayHover}" />
    <SolidColorBrush x:Key="BrushOverlayPress"      Color="{StaticResource ColorOverlayPress}" />
    <SolidColorBrush x:Key="BrushCaptionCloseHover" Color="{StaticResource ColorCaptionCloseHover}" />
    <SolidColorBrush x:Key="BrushCaptionClosePress" Color="{StaticResource ColorCaptionClosePress}" />

    <!-- ── 3. Corner Radius ────────────────────────────────────────── -->

    <!-- Buttons, inputs, small controls (3 px) -->
    <CornerRadius x:Key="RadiusControl">3</CornerRadius>
    <!-- Panels, larger containers (4 px) -->
    <CornerRadius x:Key="RadiusMedium">4</CornerRadius>

    <!-- ── 4. Typography ───────────────────────────────────────────── -->

    <!-- Window caption / labels -->
    <x:Double x:Key="FontSizeCaption">12</x:Double>
    <!-- UI chrome: menus, toolbar labels -->
    <x:Double x:Key="FontSizeBase">13</x:Double>
    <!-- Markdown editor text -->
    <x:Double x:Key="FontSizeEditor">14</x:Double>

    <FontFamily x:Key="FontFamilyEditor">Consolas, Courier New, monospace</FontFamily>

    <!-- ── 5. Sizes ─────────────────────────────────────────────────── -->

    <!-- Formatting toolbar buttons -->
    <x:Double x:Key="ToolbarButtonHeight">28</x:Double>
    <x:Double x:Key="ToolbarButtonMinWidth">36</x:Double>

    <!-- Windows custom caption buttons -->
    <x:Double x:Key="CaptionButtonWidth">46</x:Double>
    <x:Double x:Key="CaptionButtonHeight">40</x:Double>

    <!-- Toolbar separator visual height -->
    <x:Double x:Key="SeparatorHeight">20</x:Double>

    <!-- ── 6. Spacing ───────────────────────────────────────────────── -->

    <!-- Individual toolbar button margin -->
    <Thickness x:Key="ToolbarButtonMargin">2</Thickness>
    <!-- Individual toolbar button padding (horizontal only so text stays centred) -->
    <Thickness x:Key="ToolbarButtonPadding">6,0</Thickness>
    <!-- Editor text area padding -->
    <Thickness x:Key="EditorPadding">8</Thickness>

</ResourceDictionary>
