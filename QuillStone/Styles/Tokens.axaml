<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  SHARED DESIGN TOKENS                                       -->
    <!--  Theme-agnostic. No color values here.                     -->
    <!--  All themes include this file at their root.               -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- ── TYPOGRAPHY ───────────────────────────────────────────── -->
    <FontFamily x:Key="Font.UI">avares://QuillStone/Assets/Fonts#Outfit, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="Font.Editor">avares://QuillStone/Assets/Fonts#JetBrains Mono, Consolas, monospace</FontFamily>
    <FontFamily x:Key="Font.Preview">avares://QuillStone/Assets/Fonts#Lora, Georgia, serif</FontFamily>

    <x:Double x:Key="FontSize.XS">10</x:Double>
    <x:Double x:Key="FontSize.SM">12</x:Double>
    <x:Double x:Key="FontSize.Base">14</x:Double>
    <x:Double x:Key="FontSize.MD">15</x:Double>
    <x:Double x:Key="FontSize.LG">17</x:Double>
    <x:Double x:Key="FontSize.XL">20</x:Double>
    <x:Double x:Key="FontSize.2XL">24</x:Double>
    <x:Double x:Key="FontSize.3XL">30</x:Double>

    <!-- ── SPACING ────────────────────────────────────────────────── -->
    <Thickness x:Key="Spacing.None">0</Thickness>
    <Thickness x:Key="Spacing.XS">2</Thickness>
    <Thickness x:Key="Spacing.SM">4</Thickness>
    <Thickness x:Key="Spacing.MD">8</Thickness>
    <Thickness x:Key="Spacing.LG">12</Thickness>
    <Thickness x:Key="Spacing.XL">16</Thickness>
    <Thickness x:Key="Spacing.2XL">24</Thickness>
    <Thickness x:Key="Spacing.3XL">32</Thickness>

    <!-- ── SHAPE ─────────────────────────────────────────────────── -->
    <CornerRadius x:Key="Radius.None">0</CornerRadius>
    <CornerRadius x:Key="Radius.SM">3</CornerRadius>
    <CornerRadius x:Key="Radius.MD">6</CornerRadius>
    <CornerRadius x:Key="Radius.LG">10</CornerRadius>
    <CornerRadius x:Key="Radius.XL">14</CornerRadius>
    <CornerRadius x:Key="Radius.Full">9999</CornerRadius>

    <!-- ── ELEVATION SHADOWS ──────────────────────────────────────── -->
    <BoxShadows x:Key="Shadow.SM">0 1 3 0 #12000000, 0 1 2 -1 #12000000</BoxShadows>
    <BoxShadows x:Key="Shadow.MD">0 4 6 -1 #1A000000, 0 2 4 -2 #1A000000</BoxShadows>
    <BoxShadows x:Key="Shadow.LG">0 10 15 -3 #1A000000, 0 4 6 -4 #1A000000</BoxShadows>
    <BoxShadows x:Key="Shadow.XL">0 20 25 -5 #1A000000, 0 8 10 -6 #1A000000</BoxShadows>

    <!-- ── ANIMATION DURATIONS ────────────────────────────────────── -->
    <x:Double x:Key="Duration.Fast">80</x:Double>
    <x:Double x:Key="Duration.Normal">160</x:Double>
    <x:Double x:Key="Duration.Slow">300</x:Double>

    <!-- ── TOOLBAR ICONS (Material Design, 24×24 fill paths) ─────── -->
    <StreamGeometry x:Key="Icon.Heading1">M3,4H5V10H9V4H11V18H9V12H5V18H3V4M14,18V16H16V6.31L13.5,7.75V5.44L16,4H18V16H20V18H14Z</StreamGeometry>
    <StreamGeometry x:Key="Icon.Heading2">M3,4H5V10H9V4H11V18H9V12H5V18H3V4M21,18H15A2,2 0 0,1 13,16C13,15.47 13.2,15 13.54,14.64L18.41,9.41C18.78,9.05 19,8.55 19,8A2,2 0 0,0 17,6A2,2 0 0,0 15,8H13A4,4 0 0,1 17,4A4,4 0 0,1 21,8C21,9.1 20.55,10.1 19.83,10.83L15,16H21V18Z</StreamGeometry>
    <StreamGeometry x:Key="Icon.Heading3">M3,4H5V10H9V4H11V18H9V12H5V18H3V4M15,4H19A2,2 0 0,1 21,6V16A2,2 0 0,1 19,18H15A2,2 0 0,1 13,16V15H15V16H19V12H15V10H19V6H15V7H13V6A2,2 0 0,1 15,4Z</StreamGeometry>
