    <StreamGeometry x:Key="Icon.BulletList">M7,5H21V7H7V5M7,13V11H21V13H7M4,4.5A1.5,1.5 0 0,1 5.5,6A1.5,1.5 0 0,1 4,7.5A1.5,1.5 0 0,1 2.5,6A1.5,1.5 0 0,1 4,4.5M4,10.5A1.5,1.5 0 0,1 5.5,12A1.5,1.5 0 0,1 4,13.5A1.5,1.5 0 0,1 2.5,12A1.5,1.5 0 0,1 4,10.5M7,19V17H21V19H7M4,16.5A1.5,1.5 0 0,1 5.5,18A1.5,1.5 0 0,1 4,19.5A1.5,1.5 0 0,1 2.5,18A1.5,1.5 0 0,1 4,16.5Z</StreamGeometry>
    <StreamGeometry x:Key="Icon.NumberedList">M7,13V11H21V13H7M7,19V17H21V19H7M7,7V5H21V7H7M3,8V5H2V4H4V8H3M2,17V16H5V20H2V19H4V18.5H3V17.5H4V17H2M4,9.5A0.5,0.5 0 0,1 4.5,10A0.5,0.5 0 0,1 4,10.5A0.5,0.5 0 0,1 3.5,10A0.5,0.5 0 0,1 4,9.5Z</StreamGeometry>
    <StreamGeometry x:Key="Icon.Blockquote">M14,17H17L19,13V7H13V13H16M6,17H9L11,13V7H5V13H8L6,17Z</StreamGeometry>
    <StreamGeometry x:Key="Icon.Checkbox">M19,19H5V5H15V3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V11H19M7.91,10.08L6.5,11.5L11,16L21,6L19.59,4.58L11,13.17L7.91,10.08Z</StreamGeometry>

</ResourceDictionary>
