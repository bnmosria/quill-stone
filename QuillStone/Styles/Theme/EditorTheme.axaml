<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  MARKDOWN EDITOR – "Vellichor" Theme                       -->
    <!--  A refined editorial aesthetic with warm typographic soul  -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- ── LIGHT PALETTE ───────────────────────────────────────── -->
    <Color x:Key="Light.Background.Base">#F7F4EF</Color>
    <Color x:Key="Light.Background.Surface">#FFFFFF</Color>
    <Color x:Key="Light.Background.Elevated">#FFFEF9</Color>
    <Color x:Key="Light.Background.Overlay">#F0EDE6</Color>
    <Color x:Key="Light.Background.Sidebar">#EDE9E1</Color>
    <Color x:Key="Light.Background.Hover">#E8E4DB</Color>
    <Color x:Key="Light.Background.Active">#DDD8CE</Color>

    <Color x:Key="Light.Text.Primary">#1A1714</Color>
    <Color x:Key="Light.Text.Secondary">#5C5751</Color>
    <Color x:Key="Light.Text.Tertiary">#8E8880</Color>
    <Color x:Key="Light.Text.Placeholder">#B5AFA7</Color>
    <Color x:Key="Light.Text.Inverse">#FAFAF8</Color>

    <Color x:Key="Light.Accent.Primary">#C0622A</Color>
    <Color x:Key="Light.Accent.Secondary">#E07A3E</Color>
    <Color x:Key="Light.Accent.Tertiary">#F2A96E</Color>
    <Color x:Key="Light.Accent.Muted">#F5E6D8</Color>

    <Color x:Key="Light.Border.Default">#D8D2C8</Color>
    <Color x:Key="Light.Border.Strong">#B8B0A6</Color>
    <Color x:Key="Light.Border.Focus">#B97A55</Color>
    <Color x:Key="Light.Border.Separator">#E4E0D8</Color>

    <Color x:Key="Light.Syntax.Heading">#1A1714</Color>
    <Color x:Key="Light.Syntax.Bold">#2D2926</Color>
    <Color x:Key="Light.Syntax.Italic">#5C5751</Color>
    <Color x:Key="Light.Syntax.Code">#8B3A10</Color>
    <Color x:Key="Light.Syntax.CodeBg">#F2EBE3</Color>
    <Color x:Key="Light.Syntax.Link">#C0622A</Color>
    <Color x:Key="Light.Syntax.Quote">#7A7268</Color>
    <Color x:Key="Light.Syntax.QuoteBorder">#C0622A</Color>
    <Color x:Key="Light.Syntax.Marker">#D4A855</Color>

    <Color x:Key="Light.Status.Success">#4A7C59</Color>
    <Color x:Key="Light.Status.Warning">#C9901E</Color>
    <Color x:Key="Light.Status.Error">#B83232</Color>
    <Color x:Key="Light.Status.Info">#2E6B9E</Color>

    <!-- ── DARK PALETTE ─────────────────────────────────────────── -->
    <Color x:Key="Dark.Background.Base">#141210</Color>
    <Color x:Key="Dark.Background.Surface">#1C1916</Color>
    <Color x:Key="Dark.Background.Elevated">#231F1B</Color>
    <Color x:Key="Dark.Background.Overlay">#2A2520</Color>
    <Color x:Key="Dark.Background.Sidebar">#181512</Color>
    <Color x:Key="Dark.Background.Hover">#2E2924</Color>
    <Color x:Key="Dark.Background.Active">#36302A</Color>

    <Color x:Key="Dark.Text.Primary">#F0EBE3</Color>
    <Color x:Key="Dark.Text.Secondary">#B8AFA4</Color>
    <Color x:Key="Dark.Text.Tertiary">#7A7068</Color>
    <Color x:Key="Dark.Text.Placeholder">#524C46</Color>
    <Color x:Key="Dark.Text.Inverse">#141210</Color>

    <Color x:Key="Dark.Accent.Primary">#E07A3E</Color>
    <Color x:Key="Dark.Accent.Secondary">#F2A96E</Color>
    <Color x:Key="Dark.Accent.Tertiary">#F5C99A</Color>
    <Color x:Key="Dark.Accent.Muted">#3D2416</Color>

    <Color x:Key="Dark.Border.Default">#332E28</Color>
    <Color x:Key="Dark.Border.Strong">#4A4540</Color>
    <Color x:Key="Dark.Border.Focus">#D09166</Color>
    <Color x:Key="Dark.Border.Separator">#2A2520</Color>

    <Color x:Key="Dark.Syntax.Heading">#F0EBE3</Color>
    <Color x:Key="Dark.Syntax.Bold">#E4DDD4</Color>
    <Color x:Key="Dark.Syntax.Italic">#B8AFA4</Color>
    <Color x:Key="Dark.Syntax.Code">#F2A96E</Color>
    <Color x:Key="Dark.Syntax.CodeBg">#261D15</Color>
    <Color x:Key="Dark.Syntax.Link">#E07A3E</Color>
    <Color x:Key="Dark.Syntax.Quote">#8A8078</Color>
    <Color x:Key="Dark.Syntax.QuoteBorder">#E07A3E</Color>
    <Color x:Key="Dark.Syntax.Marker">#C9901E</Color>

    <Color x:Key="Dark.Status.Success">#5C9E70</Color>
    <Color x:Key="Dark.Status.Warning">#D4A030</Color>
    <Color x:Key="Dark.Status.Error">#D45050</Color>
    <Color x:Key="Dark.Status.Info">#4A90C0</Color>

    <!-- ── SEMANTIC BRUSHES (Light) ─────────────────────────────── -->
    <SolidColorBrush x:Key="Light.Brush.Background.Base"    Color="{StaticResource Light.Background.Base}"/>
    <SolidColorBrush x:Key="Light.Brush.Background.Surface" Color="{StaticResource Light.Background.Surface}"/>
    <SolidColorBrush x:Key="Light.Brush.Background.Elevated" Color="{StaticResource Light.Background.Elevated}"/>
    <SolidColorBrush x:Key="Light.Brush.Background.Overlay" Color="{StaticResource Light.Background.Overlay}"/>
    <SolidColorBrush x:Key="Light.Brush.Background.Sidebar" Color="{StaticResource Light.Background.Sidebar}"/>
    <SolidColorBrush x:Key="Light.Brush.Background.Hover"   Color="{StaticResource Light.Background.Hover}"/>
    <SolidColorBrush x:Key="Light.Brush.Background.Active"  Color="{StaticResource Light.Background.Active}"/>

    <SolidColorBrush x:Key="Light.Brush.Text.Primary"       Color="{StaticResource Light.Text.Primary}"/>
    <SolidColorBrush x:Key="Light.Brush.Text.Secondary"     Color="{StaticResource Light.Text.Secondary}"/>
    <SolidColorBrush x:Key="Light.Brush.Text.Tertiary"      Color="{StaticResource Light.Text.Tertiary}"/>
    <SolidColorBrush x:Key="Light.Brush.Text.Placeholder"   Color="{StaticResource Light.Text.Placeholder}"/>

    <SolidColorBrush x:Key="Light.Brush.Accent.Primary"     Color="{StaticResource Light.Accent.Primary}"/>
    <SolidColorBrush x:Key="Light.Brush.Accent.Secondary"   Color="{StaticResource Light.Accent.Secondary}"/>
    <SolidColorBrush x:Key="Light.Brush.Accent.Muted"       Color="{StaticResource Light.Accent.Muted}"/>

    <SolidColorBrush x:Key="Light.Brush.Border.Default"     Color="{StaticResource Light.Border.Default}"/>
    <SolidColorBrush x:Key="Light.Brush.Border.Strong"      Color="{StaticResource Light.Border.Strong}"/>
    <SolidColorBrush x:Key="Light.Brush.Border.Focus"       Color="{StaticResource Light.Border.Focus}"/>
    <SolidColorBrush x:Key="Light.Brush.Border.Separator"   Color="{StaticResource Light.Border.Separator}"/>

    <!-- ── SEMANTIC BRUSHES (Dark) ──────────────────────────────── -->
    <SolidColorBrush x:Key="Dark.Brush.Background.Base"     Color="{StaticResource Dark.Background.Base}"/>
    <SolidColorBrush x:Key="Dark.Brush.Background.Surface"  Color="{StaticResource Dark.Background.Surface}"/>
    <SolidColorBrush x:Key="Dark.Brush.Background.Elevated" Color="{StaticResource Dark.Background.Elevated}"/>
    <SolidColorBrush x:Key="Dark.Brush.Background.Overlay"  Color="{StaticResource Dark.Background.Overlay}"/>
    <SolidColorBrush x:Key="Dark.Brush.Background.Sidebar"  Color="{StaticResource Dark.Background.Sidebar}"/>
    <SolidColorBrush x:Key="Dark.Brush.Background.Hover"    Color="{StaticResource Dark.Background.Hover}"/>
    <SolidColorBrush x:Key="Dark.Brush.Background.Active"   Color="{StaticResource Dark.Background.Active}"/>

    <SolidColorBrush x:Key="Dark.Brush.Text.Primary"        Color="{StaticResource Dark.Text.Primary}"/>
    <SolidColorBrush x:Key="Dark.Brush.Text.Secondary"      Color="{StaticResource Dark.Text.Secondary}"/>
    <SolidColorBrush x:Key="Dark.Brush.Text.Tertiary"       Color="{StaticResource Dark.Text.Tertiary}"/>
    <SolidColorBrush x:Key="Dark.Brush.Text.Placeholder"    Color="{StaticResource Dark.Text.Placeholder}"/>

    <SolidColorBrush x:Key="Dark.Brush.Accent.Primary"      Color="{StaticResource Dark.Accent.Primary}"/>
    <SolidColorBrush x:Key="Dark.Brush.Accent.Secondary"    Color="{StaticResource Dark.Accent.Secondary}"/>
    <SolidColorBrush x:Key="Dark.Brush.Accent.Muted"        Color="{StaticResource Dark.Accent.Muted}"/>

    <SolidColorBrush x:Key="Dark.Brush.Border.Default"      Color="{StaticResource Dark.Border.Default}"/>
    <SolidColorBrush x:Key="Dark.Brush.Border.Strong"       Color="{StaticResource Dark.Border.Strong}"/>
    <SolidColorBrush x:Key="Dark.Brush.Border.Focus"        Color="{StaticResource Dark.Border.Focus}"/>
    <SolidColorBrush x:Key="Dark.Brush.Border.Separator"    Color="{StaticResource Dark.Border.Separator}"/>

    <!-- ── TYPOGRAPHY ───────────────────────────────────────────── -->
    <!--  UI Font: "Geist" feel – swap for your preferred sans      -->
    <!--  Editor Font: Monospace with warm character                -->

    <FontFamily x:Key="Font.UI">avares://QuillStone/Assets/Fonts#Outfit, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="Font.Editor">avares://QuillStone/Assets/Fonts#JetBrains Mono, Consolas, monospace</FontFamily>
    <FontFamily x:Key="Font.Preview">avares://QuillStone/Assets/Fonts#Lora, Georgia, serif</FontFamily>

    <x:Double x:Key="FontSize.XS">10</x:Double>
    <x:Double x:Key="FontSize.SM">12</x:Double>
    <x:Double x:Key="FontSize.Base">14</x:Double>
    <x:Double x:Key="FontSize.MD">15</x:Double>
    <x:Double x:Key="FontSize.LG">17</x:Double>
    <x:Double x:Key="FontSize.XL">20</x:Double>
    <x:Double x:Key="FontSize.2XL">24</x:Double>
    <x:Double x:Key="FontSize.3XL">30</x:Double>

    <!-- ── SPACING & SHAPE ──────────────────────────────────────── -->
    <Thickness x:Key="Spacing.None">0</Thickness>
    <Thickness x:Key="Spacing.XS">2</Thickness>
    <Thickness x:Key="Spacing.SM">4</Thickness>
    <Thickness x:Key="Spacing.MD">8</Thickness>
    <Thickness x:Key="Spacing.LG">12</Thickness>
    <Thickness x:Key="Spacing.XL">16</Thickness>
    <Thickness x:Key="Spacing.2XL">24</Thickness>
    <Thickness x:Key="Spacing.3XL">32</Thickness>

    <CornerRadius x:Key="Radius.None">0</CornerRadius>
    <CornerRadius x:Key="Radius.SM">3</CornerRadius>
    <CornerRadius x:Key="Radius.MD">6</CornerRadius>
    <CornerRadius x:Key="Radius.LG">10</CornerRadius>
    <CornerRadius x:Key="Radius.XL">14</CornerRadius>
    <CornerRadius x:Key="Radius.Full">9999</CornerRadius>

    <!-- ── ELEVATION SHADOWS ────────────────────────────────────── -->
    <BoxShadows x:Key="Shadow.SM">0 1 3 0 #12000000, 0 1 2 -1 #12000000</BoxShadows>
    <BoxShadows x:Key="Shadow.MD">0 4 6 -1 #1A000000, 0 2 4 -2 #1A000000</BoxShadows>
    <BoxShadows x:Key="Shadow.LG">0 10 15 -3 #1A000000, 0 4 6 -4 #1A000000</BoxShadows>
    <BoxShadows x:Key="Shadow.XL">0 20 25 -5 #1A000000, 0 8 10 -6 #1A000000</BoxShadows>

    <!-- ── ANIMATION DURATIONS ──────────────────────────────────── -->
    <x:Double x:Key="Duration.Fast">80</x:Double>
    <x:Double x:Key="Duration.Normal">160</x:Double>
    <x:Double x:Key="Duration.Slow">300</x:Double>

    <!-- ── TOOLBAR ICONS (Material Design, 24×24 fill paths) ─────── -->
    <StreamGeometry x:Key="Icon.Heading1">M3,4H5V10H9V4H11V18H9V12H5V18H3V4M14,18V16H16V6.31L13.5,7.75V5.44L16,4H18V16H20V18H14Z</StreamGeometry>
