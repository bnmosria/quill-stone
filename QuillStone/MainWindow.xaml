<Window x:Class="QuillStone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Quill-Stone" Height="600" Width="900"
        Closing="Window_Closing">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{x:Static ApplicationCommands.New}" />
        <KeyBinding Key="O" Modifiers="Control" Command="{x:Static ApplicationCommands.Open}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{x:Static ApplicationCommands.Save}" />
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{x:Static ApplicationCommands.SaveAs}" />
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.New}"    Executed="MenuNew_Click" />
        <CommandBinding Command="{x:Static ApplicationCommands.Open}"   Executed="MenuOpen_Click" />
        <CommandBinding Command="{x:Static ApplicationCommands.Save}"   Executed="MenuSave_Click" />
        <CommandBinding Command="{x:Static ApplicationCommands.SaveAs}" Executed="MenuSaveAs_Click" />
    </Window.CommandBindings>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New"     Command="{x:Static ApplicationCommands.New}"    InputGestureText="Ctrl+N" />
                <MenuItem Header="_Open…"   Command="{x:Static ApplicationCommands.Open}"   InputGestureText="Ctrl+O" />
                <MenuItem Header="_Save"    Command="{x:Static ApplicationCommands.Save}"   InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As…" Command="{x:Static ApplicationCommands.SaveAs}" InputGestureText="Ctrl+Shift+S" />
                <Separator />
                <MenuItem Header="E_xit" Click="MenuExit_Click" />
            </MenuItem>
        </Menu>

        <TextBox x:Name="Editor"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas, Courier New, monospace"
                 FontSize="14"
                 VerticalContentAlignment="Top"
                 Padding="8"
                 SpellCheck.IsEnabled="False"
                 TextChanged="Editor_TextChanged" />
    </DockPanel>
</Window>
