<Window x:Class="QuillStone.Views.PreviewWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preview – QuillStone"
        Width="720" Height="800"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Icon="avares://QuillStone/Assets/Icons/icon.png"
        Background="{DynamicResource Brush.Background.Elevated}">

    <ScrollViewer x:Name="PreviewScrollViewer"
                  Padding="40,32">
        <StackPanel x:Name="PreviewContent"
                    Spacing="0"
                    MaxWidth="680"
                    HorizontalAlignment="Left" />
    </ScrollViewer>

</Window>
