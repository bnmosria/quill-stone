<Window x:Class="QuillStone.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="RootWindow"
        Title="QuillStone" Height="600" Width="900"
        MinWidth="480" MinHeight="320"
        Closing="Window_Closing"
        Background="{DynamicResource BrushWindowChrome}">

    <DockPanel>

        <!-- Windows custom title bar; hidden on platforms that use native window chrome -->
        <Grid x:Name="TitleBar"
              DockPanel.Dock="Top"
              Height="{DynamicResource CaptionButtonHeight}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Drag region + app title -->
            <Border Grid.Column="0"
                    Background="Transparent"
                    PointerPressed="TitleBar_PointerPressed"
                    DoubleTapped="TitleBar_DoubleTapped">
                <TextBlock Text="{Binding Title, ElementName=RootWindow}"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           FontSize="{DynamicResource FontSizeCaption}"
                           Opacity="0.72" />
            </Border>

            <!-- Right-aligned caption buttons -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                <Button x:Name="MinimizeButton"
                        Content="&#x2212;"
                        ToolTip.Tip="Minimize"
                        Click="CaptionMinimize_Click"
                        Classes="caption-button" />
                <Button x:Name="MaximizeButton"
                        Content="&#x25A1;"
                        ToolTip.Tip="Maximize"
                        Click="CaptionMaximize_Click"
                        Classes="caption-button" />
                <Button x:Name="CloseButton"
                        Content="&#x2715;"
                        ToolTip.Tip="Close"
                        Click="CaptionClose_Click"
                        Classes="caption-button caption-close" />
            </StackPanel>
        </Grid>

        <!-- Opaque content area so editor and toolbars are fully readable -->
        <Border Background="{DynamicResource BrushSurface}"
                CornerRadius="0">
            <DockPanel>

                <Menu DockPanel.Dock="Top">
                    <MenuItem Header="_File">
                        <MenuItem Header="_New" HotKey="Ctrl+N" Click="MenuNew_Click" />
                        <MenuItem Header="_Open..." HotKey="Ctrl+O" Click="MenuOpen_Click" />
                        <MenuItem Header="_Save" HotKey="Ctrl+S" Click="MenuSave_Click" />
                        <MenuItem Header="Save _As..." HotKey="Ctrl+Shift+S" Click="MenuSaveAs_Click" />
                        <Separator />
                        <MenuItem Header="E_xit" Click="MenuExit_Click" />
                    </MenuItem>
                </Menu>

                <WrapPanel x:Name="FormattingToolbar"
                           DockPanel.Dock="Top"
                           Orientation="Horizontal"
                           Background="{DynamicResource BrushSurfaceAlt}"
                           HorizontalAlignment="Stretch">
                    <Button Content="B" FontWeight="Bold"
                            ToolTip.Tip="Bold (Ctrl+B)"
                            AutomationProperties.Name="Bold"
                            Click="ToolbarBold_Click"
                            Classes="toolbar-btn" />
                    <Button Content="I" FontStyle="Italic"
                            ToolTip.Tip="Italic (Ctrl+I)"
                            AutomationProperties.Name="Italic"
                            Click="ToolbarItalic_Click"
                            Classes="toolbar-btn" />
                    <Button Content="` `" FontFamily="{DynamicResource FontFamilyEditor}"
                            ToolTip.Tip="Inline Code"
                            AutomationProperties.Name="Inline Code"
                            Click="ToolbarInlineCode_Click"
                            Classes="toolbar-btn" />
                    <Button Content="🔗"
                            ToolTip.Tip="Insert Link (Ctrl+K)"
                            AutomationProperties.Name="Insert Link"
                            Click="ToolbarLink_Click"
                            Classes="toolbar-btn" />
                    <Separator Width="1"
                               Height="{DynamicResource SeparatorHeight}"
                               Background="{DynamicResource BrushBorder}"
                               Margin="4,2" />
                    <Button Content="H1" FontWeight="Bold"
                            ToolTip.Tip="Heading 1 (Ctrl+H)"
                            AutomationProperties.Name="Heading 1"
                            Click="ToolbarH1_Click"
                            Classes="toolbar-btn" />
                    <Button Content="H2" FontWeight="Bold"
                            ToolTip.Tip="Heading 2"
                            AutomationProperties.Name="Heading 2"
                            Click="ToolbarH2_Click"
                            Classes="toolbar-btn" />
                    <Button Content="H3" FontWeight="Bold"
                            ToolTip.Tip="Heading 3"
                            AutomationProperties.Name="Heading 3"
                            Click="ToolbarH3_Click"
                            Classes="toolbar-btn" />
                    <Separator Width="1"
                               Height="{DynamicResource SeparatorHeight}"
                               Background="{DynamicResource BrushBorder}"
                               Margin="4,2" />
                    <Button Content="• List"
                            ToolTip.Tip="Bullet List"
                            AutomationProperties.Name="Bullet List"
                            Click="ToolbarBulletList_Click"
                            Classes="toolbar-btn" />
                    <Button Content="1. List"
                            ToolTip.Tip="Numbered List"
                            AutomationProperties.Name="Numbered List"
                            Click="ToolbarNumberedList_Click"
                            Classes="toolbar-btn" />
                    <Separator Width="1"
                               Height="{DynamicResource SeparatorHeight}"
                               Background="{DynamicResource BrushBorder}"
                               Margin="4,2" />
                    <Button Content="❝"
                            ToolTip.Tip="Blockquote"
                            AutomationProperties.Name="Blockquote"
                            Click="ToolbarBlockquote_Click"
                            Classes="toolbar-btn" />
                    <Button Content="☑"
                            ToolTip.Tip="Checkbox"
                            AutomationProperties.Name="Checkbox"
                            Click="ToolbarCheckbox_Click"
                            Classes="toolbar-btn" />
                </WrapPanel>

                <TextBox x:Name="Editor"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         FontFamily="{DynamicResource FontFamilyEditor}"
                         FontSize="{DynamicResource FontSizeEditor}"
                         VerticalContentAlignment="Top"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         Padding="{DynamicResource EditorPadding}"
                         CornerRadius="{DynamicResource RadiusMedium}"
                         TextChanged="Editor_TextChanged"
                         KeyDown="Editor_KeyDown" />
            </DockPanel>
        </Border>
    </DockPanel>
</Window>

