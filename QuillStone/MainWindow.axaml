<Window x:Class="QuillStone.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="RootWindow"
        Title="QuillStone" Height="800" Width="1280"
        MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        Icon="avares://QuillStone/Assets/Icons/icon.png"
        Background="{DynamicResource Brush.Background.Base}">

    <DockPanel>

        <!-- Windows custom title bar; hidden on platforms that use native window chrome -->
        <Grid x:Name="TitleBar"
              DockPanel.Dock="Top"
              Height="44"
              Background="{DynamicResource Brush.Background.Surface}"
              Margin="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Drag region + app title -->
            <Border Grid.Column="0"
                    Background="Transparent"
                    PointerPressed="TitleBar_PointerPressed"
                    DoubleTapped="TitleBar_DoubleTapped">
                <TextBlock Text="{Binding Title, ElementName=RootWindow}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"
                           FontFamily="{DynamicResource Font.UI}"
                           FontSize="{DynamicResource FontSize.Base}"
                           Foreground="{DynamicResource Brush.Text.Secondary}" />
            </Border>

            <!-- Right-aligned caption buttons -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                <Button x:Name="MinimizeButton"
                        Content="&#x2212;"
                        ToolTip.Tip="Minimize"
                        Click="CaptionMinimize_Click"
                        Classes="caption-button" />
                <Button x:Name="MaximizeButton"
                        Content="&#x25A1;"
                        ToolTip.Tip="Maximize"
                        Click="CaptionMaximize_Click"
                        Classes="caption-button" />
                <Button x:Name="CloseButton"
                        Content="&#x2715;"
                        ToolTip.Tip="Close"
                        Click="CaptionClose_Click"
                        Classes="caption-button caption-close" />
            </StackPanel>
        </Grid>

        <!-- Opaque content area so editor and toolbars are fully readable -->
        <Border Background="{DynamicResource Brush.Background.Surface}"
                CornerRadius="0">
            <DockPanel>

                <Menu DockPanel.Dock="Top">
                    <MenuItem Header="_File">
                        <MenuItem Header="_New" HotKey="Ctrl+N" Click="MenuNew_Click" />
                        <MenuItem Header="_Open..." HotKey="Ctrl+O" Click="MenuOpen_Click" />
                        <MenuItem Header="_Save" HotKey="Ctrl+S" Click="MenuSave_Click" />
                        <MenuItem Header="Save _As..." HotKey="Ctrl+Shift+S" Click="MenuSaveAs_Click" />
                        <Separator />
                        <MenuItem Header="E_xit" Click="MenuExit_Click" />
                    </MenuItem>
                    <MenuItem Header="_View">
                        <MenuItem Header="Toggle _Theme" HotKey="Ctrl+Shift+T" Click="MenuToggleTheme_Click" />
                    </MenuItem>
                    <MenuItem Header="_Help">
                        <MenuItem Header="_About QuillStone..." Click="MenuAbout_Click" />
                    </MenuItem>
                </Menu>

                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource Brush.Background.Overlay}"
                        BorderBrush="{DynamicResource Brush.Border.Separator}"
                        BorderThickness="0,1,0,1"
                        Padding="16,10,16,10">
                    <StackPanel x:Name="FormattingToolbar"
                                Orientation="Horizontal"
                                Spacing="2"
                                VerticalAlignment="Center">
                        <Button ToolTip.Tip="Heading 1 (Ctrl+H)"
                                AutomationProperties.Name="Heading 1"
                                Click="ToolbarH1_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Heading1}" Width="14" Height="14"/>
                        </Button>
                        <Button ToolTip.Tip="Heading 2"
                                AutomationProperties.Name="Heading 2"
                                Click="ToolbarH2_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Heading2}" Width="14" Height="14"/>
                        </Button>
                        <Button ToolTip.Tip="Heading 3"
                                AutomationProperties.Name="Heading 3"
                                Click="ToolbarH3_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Heading3}" Width="14" Height="14"/>
                        </Button>
                        <Separator Classes="ToolbarSeparator" />
                        <Button ToolTip.Tip="Bold (Ctrl+B)"
                                AutomationProperties.Name="Bold"
                                Click="ToolbarBold_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Bold}" Width="14" Height="14"/>
                        </Button>
                        <Button ToolTip.Tip="Italic (Ctrl+I)"
                                AutomationProperties.Name="Italic"
                                Click="ToolbarItalic_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Italic}" Width="14" Height="14"/>
                        </Button>
                        <Button ToolTip.Tip="Inline Code"
                                AutomationProperties.Name="Inline Code"
                                Click="ToolbarInlineCode_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Code}" Width="14" Height="14"/>
                        </Button>
                        <Button ToolTip.Tip="Insert Link (Ctrl+K)"
                                AutomationProperties.Name="Insert Link"
                                Click="ToolbarLink_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Link}" Width="14" Height="14"/>
                        </Button>
                        <Separator Classes="ToolbarSeparator" />
                        <Button ToolTip.Tip="Bullet List"
                                AutomationProperties.Name="Bullet List"
                                Click="ToolbarBulletList_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.BulletList}" Width="14" Height="14"/>
                        </Button>
                        <Button ToolTip.Tip="Numbered List"
                                AutomationProperties.Name="Numbered List"
                                Click="ToolbarNumberedList_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.NumberedList}" Width="14" Height="14"/>
                        </Button>
                        <Separator Classes="ToolbarSeparator" />
                        <Button ToolTip.Tip="Blockquote"
                                AutomationProperties.Name="Blockquote"
                                Click="ToolbarBlockquote_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Blockquote}" Width="14" Height="14"/>
                        </Button>
                        <Button ToolTip.Tip="Checkbox"
                                AutomationProperties.Name="Checkbox"
                                Click="ToolbarCheckbox_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Checkbox}" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom"
                        Classes="StatusBar">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Ln 1, Col 1  *  UTF-8  *  Markdown"
                                   Classes="StatusMetaPrimary"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,1" />
                        <TextBlock Grid.Column="1"
                                   Text="247 words  *  1.2 min read"
                                   Classes="StatusMetaSecondary"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,1" />
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="210,*">
                    <Border Grid.Column="0"
                            Background="{DynamicResource Brush.Background.Sidebar}"
                            BorderBrush="{DynamicResource Brush.Border.Separator}"
                            BorderThickness="0,0,1,0"
                            Padding="16,16,12,14">
                        <StackPanel Spacing="6">
                            <TextBlock Text="OPEN"
                                       Classes="SidebarSectionTitle" />
                            <Border Classes="SidebarActiveItem"
                                    Background="{DynamicResource Brush.Accent.Muted}">
                                <TextBlock Text="README"
                                           Classes="SidebarActiveItemText"
                                           Foreground="{DynamicResource Brush.Accent.Primary}" />
                            </Border>
                            <TextBlock Text="notes"
                                       Classes="SidebarItem"
                                       Foreground="{DynamicResource Brush.Text.Secondary}" />
                            <TextBlock Text="CHANGELOG"
                                       Classes="SidebarItem"
                                       Foreground="{DynamicResource Brush.Text.Secondary}" />
                            <TextBlock Text="RECENT"
                                       Classes="SidebarSectionTitle"
                                       Margin="0,16,0,0" />
                            <TextBlock Text="guide"
                                       Classes="SidebarItem"
                                       Foreground="{DynamicResource Brush.Text.Tertiary}" />
                            <TextBlock Text="blog"
                                       Classes="SidebarItem"
                                       Foreground="{DynamicResource Brush.Text.Tertiary}" />
                        </StackPanel>
                    </Border>

                    <TextBox x:Name="Editor"
                             Grid.Column="1"
                             Classes="CodeEditor"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalContentAlignment="Top"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             TextChanged="Editor_TextChanged"
                             KeyDown="Editor_KeyDown" />
                </Grid>
            </DockPanel>
        </Border>
    </DockPanel>
</Window>

