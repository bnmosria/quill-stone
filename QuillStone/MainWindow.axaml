<Window x:Class="QuillStone.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QuillStone.ViewModels"
        x:Name="RootWindow"
        Title="QuillStone" Height="800" Width="1280"
        MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        Icon="avares://QuillStone/Assets/Icons/icon.png"
        Background="{DynamicResource Brush.Background.Base}">

    <DockPanel>

        <!-- Windows custom title bar; hidden on platforms that use native window chrome -->
        <Grid x:Name="TitleBar"
              DockPanel.Dock="Top"
              Height="44"
              Background="{DynamicResource Brush.Background.Surface}"
              Margin="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Drag region + app title -->
            <Border Grid.Column="0"
                    Background="Transparent"
                    PointerPressed="TitleBar_PointerPressed"
                    DoubleTapped="TitleBar_DoubleTapped">
                <TextBlock Text="{Binding Title, ElementName=RootWindow}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"
                           FontFamily="{DynamicResource Font.UI}"
                           FontSize="{DynamicResource FontSize.Base}"
                           Foreground="{DynamicResource Brush.Text.Secondary}" />
            </Border>

            <!-- Right-aligned caption buttons -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                <Button x:Name="MinimizeButton"
                        Content="&#x2212;"
                        ToolTip.Tip="Minimize"
                        Click="CaptionMinimize_Click"
                        Classes="caption-button" />
                <Button x:Name="MaximizeButton"
                        Content="&#x25A1;"
                        ToolTip.Tip="Maximize"
                        Click="CaptionMaximize_Click"
                        Classes="caption-button" />
                <Button x:Name="CloseButton"
                        Content="&#x2715;"
                        ToolTip.Tip="Close"
                        Click="CaptionClose_Click"
                        Classes="caption-button caption-close" />
            </StackPanel>
        </Grid>

        <!-- Opaque content area so editor and toolbars are fully readable -->
        <Border x:Name="WindowSurface"
            Background="{DynamicResource Brush.Background.Surface}"
            CornerRadius="0"
            Focusable="True"
            PointerPressed="WindowSurface_PointerPressed">
            <DockPanel>

                <Menu DockPanel.Dock="Top">
                    <MenuItem Header="_File">
                        <MenuItem Header="_New" HotKey="Ctrl+N" Click="MenuNew_Click" />
                        <MenuItem Header="_Open..." HotKey="Ctrl+O" Click="MenuOpen_Click" />
                        <MenuItem Header="_Save" HotKey="Ctrl+S" Click="MenuSave_Click" />
                        <MenuItem Header="Save _As..." HotKey="Ctrl+Shift+S" Click="MenuSaveAs_Click" />
                        <Separator />
                        <MenuItem Header="E_xit" Click="MenuExit_Click" />
                    </MenuItem>
                    <MenuItem Header="_Project">
                        <MenuItem Header="Open _Folder..." Click="MenuOpenFolder_Click" />
                        <MenuItem Header="_New Project..." Click="MenuNewProject_Click" />
                        <Separator />
                        <MenuItem x:Name="RecentProjectsMenuItem" Header="_Recent Projects" />
                    </MenuItem>
                    <MenuItem Header="_View">
                        <MenuItem Header="Toggle _Theme" HotKey="Ctrl+Shift+T" Click="MenuToggleTheme_Click" />
                        <Separator />
                        <MenuItem x:Name="MenuSplitView"
                                  Header="_Split View"
                                  HotKey="Ctrl+Shift+P"
                                  Click="MenuSplitView_Click" />
                        <MenuItem x:Name="MenuFullPreview"
                                  Header="_Full Preview"
                                  HotKey="Ctrl+Shift+F"
                                  Click="MenuFullPreview_Click" />
                    </MenuItem>
                    <MenuItem Header="_Help">
                        <MenuItem Header="_About QuillStone..." Click="MenuAbout_Click" />
                    </MenuItem>
                </Menu>

                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource Brush.Background.Overlay}"
                        BorderBrush="{DynamicResource Brush.Border.Separator}"
                        BorderThickness="0,1,0,1"
                        Padding="16,10,16,10">
                    <StackPanel x:Name="FormattingToolbar"
                                Orientation="Horizontal"
                                Spacing="2"
                                VerticalAlignment="Center">
                        <Button ToolTip.Tip="Heading 1 (Ctrl+H)"
                                AutomationProperties.Name="Heading 1"
                                Click="ToolbarH1_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Heading1}" Width="14" Height="14"/>
                        </Button>
                        <Button ToolTip.Tip="Heading 2"
                                AutomationProperties.Name="Heading 2"
                                Click="ToolbarH2_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Heading2}" Width="14" Height="14"/>
                        </Button>
                        <Button ToolTip.Tip="Heading 3"
                                AutomationProperties.Name="Heading 3"
                                Click="ToolbarH3_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Heading3}" Width="14" Height="14"/>
                        </Button>
                        <Separator Classes="ToolbarSeparator" />
                        <Button ToolTip.Tip="Bold (Ctrl+B)"
                                AutomationProperties.Name="Bold"
                                Click="ToolbarBold_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Bold}" Width="14" Height="14"/>
                        </Button>
                        <Button ToolTip.Tip="Italic (Ctrl+I)"
                                AutomationProperties.Name="Italic"
                                Click="ToolbarItalic_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Italic}" Width="14" Height="14"/>
                        </Button>
                        <Button ToolTip.Tip="Inline Code"
                                AutomationProperties.Name="Inline Code"
                                Click="ToolbarInlineCode_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Code}" Width="14" Height="14"/>
                        </Button>
                        <Button ToolTip.Tip="Insert Link (Ctrl+K)"
                                AutomationProperties.Name="Insert Link"
                                Click="ToolbarLink_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Link}" Width="14" Height="14"/>
                        </Button>
                        <Separator Classes="ToolbarSeparator" />
                        <Button ToolTip.Tip="Bullet List"
                                AutomationProperties.Name="Bullet List"
                                Click="ToolbarBulletList_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.BulletList}" Width="14" Height="14"/>
                        </Button>
                        <Button ToolTip.Tip="Numbered List"
                                AutomationProperties.Name="Numbered List"
                                Click="ToolbarNumberedList_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.NumberedList}" Width="14" Height="14"/>
                        </Button>
                        <Separator Classes="ToolbarSeparator" />
                        <Button ToolTip.Tip="Blockquote"
                                AutomationProperties.Name="Blockquote"
                                Click="ToolbarBlockquote_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Blockquote}" Width="14" Height="14"/>
                        </Button>
                        <Button ToolTip.Tip="Checkbox"
                                AutomationProperties.Name="Checkbox"
                                Click="ToolbarCheckbox_Click"
                                Classes="Toolbar Ghost">
                            <PathIcon Data="{DynamicResource Icon.Checkbox}" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom"
                        Classes="StatusBar">
                    <Grid ColumnDefinitions="*,Auto,*">

                        <!-- Left: line, column, encoding, file type -->
                        <TextBlock x:Name="StatusMeta"
                                   Text="Ln 1, Col 1  ·  UTF-8  ·  Markdown"
                                   FontFamily="{DynamicResource Font.UI}"
                                   FontSize="{DynamicResource FontSize.XS}"
                                   Foreground="{DynamicResource Brush.Text.Tertiary}"
                                   VerticalAlignment="Center" />

                        <!-- Centre: three view-mode toggle buttons -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="2"
                                    VerticalAlignment="Center">
                            <Button x:Name="ViewEditorOnlyButton"
                                    ToolTip.Tip="Editor Only"
                                    Click="ViewEditorOnly_Click"
                                    Classes="Ghost"
                                    Padding="5">
                                <PathIcon Data="{DynamicResource Icon.ViewEditorOnly}" Width="14" Height="14"/>
                            </Button>
                            <Button x:Name="ViewSplitButton"
                                    ToolTip.Tip="Split View"
                                    Click="ViewSplit_Click"
                                    Classes="Ghost"
                                    Padding="5">
                                <PathIcon Data="{DynamicResource Icon.ViewSplit}" Width="14" Height="14"/>
                            </Button>
                            <Button x:Name="ViewFullPreviewButton"
                                    ToolTip.Tip="Full Preview"
                                    Click="ViewFullPreview_Click"
                                    Classes="Ghost"
                                    Padding="5">
                                <PathIcon Data="{DynamicResource Icon.ViewFullPreview}" Width="14" Height="14"/>
                            </Button>
                        </StackPanel>

                        <!-- Right: word count + reading time + theme toggle -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="4"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="StatusWordCount"
                                       Text="0 words · 0 min read"
                                       FontFamily="{DynamicResource Font.UI}"
                                       FontSize="{DynamicResource FontSize.XS}"
                                       Foreground="{DynamicResource Brush.Text.Tertiary}"
                                       VerticalAlignment="Center" />
                            <Button ToolTip.Tip="Toggle Theme"
                                    Click="MenuToggleTheme_Click"
                                    Classes="Ghost"
                                    Padding="5">
                                <PathIcon Data="{DynamicResource Icon.Moon}" Width="14" Height="14"/>
                            </Button>
                        </StackPanel>

                    </Grid>
                </Border>

                <Grid ColumnDefinitions="210,*">
                    <!-- Outer grid: sidebar (col 0) + editor/preview area (col 1) -->
                    <!-- The inner EditorPreviewGrid handles the split -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource Brush.Background.Sidebar}"
                            BorderBrush="{DynamicResource Brush.Border.Separator}"
                            BorderThickness="0,0,1,0">
                        <DockPanel>
                            <Border DockPanel.Dock="Top"
                                    Padding="16,12,12,6"
                                    BorderBrush="{DynamicResource Brush.Border.Separator}"
                                    BorderThickness="0,0,0,1">
                                <TextBlock Text="EXPLORER"
                                           Classes="SidebarSectionTitle"
                                           Margin="0"/>
                            </Border>

                                <StackPanel x:Name="SidebarNoProjectActions"
                                    DockPanel.Dock="Top"
                                    Margin="16,8,12,0"
                                    IsVisible="True"
                                    Spacing="4">
                                <TextBlock Text="Open File"
                                       Classes="SidebarItem"
                                       Cursor="Hand"
                                       TextDecorations="Underline"
                                       Foreground="{DynamicResource Brush.Accent.Primary}"
                                       Tapped="SidebarOpenFile_Tapped"/>
                                <TextBlock Text="Open Folder"
                                       Classes="SidebarItem"
                                       Cursor="Hand"
                                       TextDecorations="Underline"
                                       Foreground="{DynamicResource Brush.Accent.Primary}"
                                       Tapped="SidebarOpenFolder_Tapped"/>
                                </StackPanel>

                            <StackPanel x:Name="SidebarOpenSection"
                                        DockPanel.Dock="Top"
                                        IsVisible="False"
                                        Margin="16,8,12,0"
                                        Spacing="4">
                                <TextBlock Text="OPEN"
                                           Classes="SidebarSectionTitle"
                                           Margin="0"/>
                                <Border Classes="SidebarActiveItem"
                                        Background="{DynamicResource Brush.Accent.Muted}">
                                    <TextBlock x:Name="CurrentFileLabel"
                                               Classes="SidebarActiveItemText"
                                               Foreground="{DynamicResource Brush.Accent.Primary}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                            </StackPanel>

                            <TreeView x:Name="ProjectTree"
                                      Classes="SidebarTree"
                                      IsVisible="False"
                                      DragDrop.AllowDrop="True"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <TreeView.DataTemplates>
                                    <TreeDataTemplate DataType="vm:FolderNodeViewModel"
                                                      ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Left">
                                            <StackPanel.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="New Markdown File" Click="FolderContextMenu_NewFile_Click"/>
                                                    <MenuItem Header="New Folder" Click="FolderContextMenu_NewFolder_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="Rename" Click="FolderContextMenu_Rename_Click"/>
                                                    <MenuItem Header="Delete" Click="FolderContextMenu_Delete_Click"/>
                                                </ContextMenu>
                                            </StackPanel.ContextMenu>
                                            <PathIcon Data="{DynamicResource Icon.Folder}"
                                                      Width="12" Height="12"
                                                      VerticalAlignment="Center"
                                                      Foreground="{DynamicResource Brush.Accent.Secondary}"/>
                                            <TextBlock Text="{Binding Name}"
                                                       Classes="ExplorerItem"/>
                                        </StackPanel>
                                    </TreeDataTemplate>
                                    <DataTemplate DataType="vm:FileNodeViewModel">
                                        <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Left">
                                            <StackPanel.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Rename" Click="FileContextMenu_Rename_Click"/>
                                                    <MenuItem Header="Delete" Click="FileContextMenu_Delete_Click"/>
                                                </ContextMenu>
                                            </StackPanel.ContextMenu>
                                            <PathIcon Data="{DynamicResource Icon.File}"
                                                      Width="12" Height="12"
                                                      VerticalAlignment="Center"
                                                      Foreground="{DynamicResource Brush.Text.Tertiary}"/>
                                            <TextBlock Text="{Binding Name}"
                                                       Classes="ExplorerItem"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </TreeView.DataTemplates>
                                <TreeView.Styles>
                                    <Style Selector="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    </Style>
                                </TreeView.Styles>
                            </TreeView>
                        </DockPanel>
                    </Border>

                    <Grid x:Name="EditorPreviewGrid"
                          Grid.Column="1"
                          ColumnDefinitions="1*,Auto,0">

                        <TextBox x:Name="Editor"
                                 Grid.Column="0"
                                 Classes="CodeEditor"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 VerticalContentAlignment="Top"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 TextChanged="Editor_TextChanged"
                                 KeyDown="Editor_KeyDown" />

                        <!-- Resizable splitter; hidden until split view is activated -->
                        <GridSplitter x:Name="PreviewSplitter"
                                      Grid.Column="1"
                                      Width="5"
                                      IsVisible="False"
                                      Background="{DynamicResource Brush.Border.Separator}"
                                      ResizeDirection="Columns" />

                        <!-- Preview pane; hidden until split view is activated -->
                        <Border x:Name="PreviewPane"
                                Grid.Column="2"
                                IsVisible="False"
                                BorderBrush="{DynamicResource Brush.Border.Separator}"
                                BorderThickness="1,0,0,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Background="{DynamicResource Brush.Background.Base}">
                                <StackPanel x:Name="PreviewContainer"
                                            Margin="24,20"
                                            Spacing="12" />
                            </ScrollViewer>
                        </Border>

                    </Grid>
                </Grid>
            </DockPanel>
        </Border>
    </DockPanel>
</Window>

