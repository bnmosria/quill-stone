<Window x:Class="QuillStone.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quill-Stone" Height="600" Width="900"
        Closing="Window_Closing">

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" HotKey="Ctrl+N" Click="MenuNew_Click" />
                <MenuItem Header="_Open..." HotKey="Ctrl+O" Click="MenuOpen_Click" />
                <MenuItem Header="_Save" HotKey="Ctrl+S" Click="MenuSave_Click" />
                <MenuItem Header="Save _As..." HotKey="Ctrl+Shift+S" Click="MenuSaveAs_Click" />
                <Separator />
                <MenuItem Header="E_xit" Click="MenuExit_Click" />
            </MenuItem>
        </Menu>

        <TextBox x:Name="Editor"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas, Courier New, monospace"
                 FontSize="14"
                 VerticalContentAlignment="Top"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 Padding="8"
                 TextChanged="Editor_TextChanged" />
    </DockPanel>
</Window>

