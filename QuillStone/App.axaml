<Application x:Class="QuillStone.App"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             RequestedThemeVariant="Default">

    <!--
        Design system entry point
        ─────────────────────────────────────────────────────────────────────
        Tokens.axaml   — all raw values (colors, radius, spacing, typography)
        ControlStyles.axaml — styles that consume those tokens
        To tweak the look, edit Tokens.axaml; the changes propagate everywhere.
    -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://QuillStone/Styles/Tokens.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://QuillStone/Styles/ControlStyles.axaml" />
    </Application.Styles>

</Application>

