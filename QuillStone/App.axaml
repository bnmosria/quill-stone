<Application x:Class="QuillStone.App"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             RequestedThemeVariant="Light">

    <Application.Styles>
        <FluentTheme>
            <FluentTheme.Palettes>
                <ColorPaletteResources x:Key="Light" Accent="#C0622A" />
                <ColorPaletteResources x:Key="Dark" Accent="#E07A3E" />
            </FluentTheme.Palettes>
        </FluentTheme>
        <StyleInclude Source="avares://QuillStone/Styles/Theme/ControlStyles.axaml" />
    </Application.Styles>

</Application>

